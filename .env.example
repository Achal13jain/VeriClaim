# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Informational only for the current MVP. The app automatically falls back to
# deterministic demo data when live provider keys are missing or fail.
NEXT_PUBLIC_DEMO_MODE=true

# AI providers - leave empty to keep deterministic demo fallback mode enabled.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Future Firebase Admin SDK path. Not used by the current client-only MVP.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Arc Testnet. Current MVP proof publishing is mock mode; contract/RPC vars are
# kept for the future real Arc publishing path.
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_VERICLAIM_CONTRACT_ADDRESS=
# Legacy fallback accepted by the contract helper, optional/future only.
NEXT_PUBLIC_MARKET_SPEC_REGISTRY_ADDRESS=

# Future Foundry deployment only. Do not set PRIVATE_KEY in browser/public envs.
PRIVATE_KEY=
ARC_RPC_URL=

# Mock x402. X402_RECEIVER_ADDRESS is reserved for future real x402 support.
NEXT_PUBLIC_X402_MODE=mock
X402_PRICE_USD=0.01
X402_RECEIVER_ADDRESS=
