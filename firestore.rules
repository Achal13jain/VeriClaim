rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function creatorSpecUpdate() {
      return signedIn()
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    function challengeSpecUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && request.resource.data.createdBy == resource.data.createdBy
        && changed.hasOnly(["status", "challengeCount", "rewardTotal"])
        && request.resource.data.challengeCount == resource.data.challengeCount + 1
        && request.resource.data.rewardTotal >= resource.data.rewardTotal
        && request.resource.data.status in [
          resource.data.status,
          "challenged",
          "needs_revision"
        ];
    }

    function arcProofSpecUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return signedIn()
        && request.resource.data.createdBy == resource.data.createdBy
        && changed.hasOnly([
          "status",
          "arcPublished",
          "arcTxHash",
          "arcPublishedAt",
          "arcMode"
        ])
        && request.resource.data.arcPublished == true
        && request.resource.data.arcTxHash is string
        && request.resource.data.arcPublishedAt is string
        && request.resource.data.arcMode in ["mock", "contract"]
        && request.resource.data.status == "published";
    }

    function validUserEconomy() {
      return request.resource.data.credits is number
        && request.resource.data.credits >= 0
        && request.resource.data.reputation is number
        && request.resource.data.reputation >= 0
        && request.resource.data.freeForgeUsed is number
        && request.resource.data.freeForgeUsed >= 0
        && request.resource.data.totalMockPayments is number
        && request.resource.data.totalMockPayments >= 0
        && request.resource.data.totalCreditsSpent is number
        && request.resource.data.totalCreditsSpent >= 0;
    }

    match /users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && validUserEconomy();
      allow delete: if isOwner(uid);
    }

    match /specs/{hash} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if creatorSpecUpdate() || challengeSpecUpdate() || arcProofSpecUpdate();
      allow delete: if isAdmin();
    }

    match /challenges/{id} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.challengerUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /feedback/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /agent_runs/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /payments/{id} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type == "forge_unlock"
        && request.resource.data.mode in ["mock_x402", "forge_credit"]
        && request.resource.data.amountUsd is number
        && request.resource.data.amountUsd >= 0
        && request.resource.data.creditsSpent is number
        && request.resource.data.creditsSpent >= 0
        && request.resource.data.txReference is string
        && request.resource.data.status == "completed";
      allow update, delete: if isAdmin();
    }

    match /arc_proofs/{id} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.publishedBy == request.auth.uid
        && request.resource.data.specHash is string
        && request.resource.data.chainId == 5042002
        && request.resource.data.chainName == "Arc Testnet"
        && request.resource.data.txHash is string
        && request.resource.data.mode in ["mock", "contract"];
      allow update, delete: if isAdmin();
    }

    match /activity_events/{id} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /agents/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /admins/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
